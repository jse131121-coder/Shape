<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SHAPE CHAT</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #F2E6FF; }
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .bubble-me { border-radius: 20px 4px 20px 20px; }
        .bubble-other { border-radius: 4px 20px 20px 20px; }
    </style>
</head>
<body class="flex justify-center items-center h-screen">

    <div id="app" class="w-full max-w-[450px] h-full md:h-[90vh] bg-[#F2E6FF] shadow-2xl flex flex-col overflow-hidden md:rounded-[3rem] border-[8px] border-white relative">
        
        <header class="flex items-center justify-between p-5 bg-white/70 backdrop-blur-md sticky top-0 z-10 border-b border-purple-100">
            <h1 class="text-3xl font-[900] tracking-tighter text-[#1E0A40]">SHAPE</h1>
            <button class="bg-gradient-to-br from-[#E2B7FD] to-[#A855F7] text-white px-6 py-2 rounded-2xl font-bold shadow-lg active:scale-95 transition-all text-sm">
                MAKE
            </button>
        </header>

        <main id="chat-window" class="flex-1 overflow-y-auto p-4 space-y-6 scrollbar-hide">
            <div class="flex justify-center">
                <span class="bg-white/50 px-3 py-1 rounded-full text-[10px] text-purple-400 font-bold uppercase tracking-widest">2026.04.16</span>
            </div>
            
            <div id="messages-container" class="space-y-6">
                </div>
        </main>

        <footer class="p-4 bg-white/80 backdrop-blur-xl border-t border-purple-100">
            <div class="flex items-center gap-3 bg-gray-50/50 p-2 rounded-[30px] border border-purple-100 shadow-inner">
                <div class="w-10 h-10 rounded-full bg-[#FFB5E8] flex-shrink-0 flex items-center justify-center font-bold text-white shadow-sm border-2 border-white">G</div>
                
                <label class="cursor-pointer p-1.5 hover:bg-purple-100 rounded-full transition-all text-[#1E0A40]">
                    <i data-lucide="camera" size="22"></i>
                    <input type="file" id="image-input" class="hidden" accept="image/*">
                </label>

                <input type="text" id="msg-input" placeholder="메시지..." class="flex-1 bg-transparent border-none focus:outline-none text-[15px] text-[#1E0A40] placeholder-purple-300">

                <button id="send-btn" class="bg-gradient-to-br from-[#E2B7FD] to-[#A855F7] text-white px-5 py-2.5 rounded-full font-bold shadow-md active:scale-95 transition-all text-sm">
                    send
                </button>
            </div>
            <div class="h-4"></div>
        </footer>
    </div>

    <script>
        // 1. 유저 데이터 (요청하신 계정 정보)
        const USERS = {
            GARIN: { name: '가린', color: 'bg-[#FFB5E8]' },
            REINA: { name: '레이나', color: 'bg-[#B5EAD7]' },
            HANSEOL: { name: '한설', color: 'bg-[#C7CEEA]' },
            RIEH: { name: '리에', color: 'bg-[#FFDAC1]' }
        };

        const ME = USERS.GARIN; // 현재 나
        let messages = [
            { user: USERS.REINA, text: "루카님 사랑해용💜", type: "text", time: "17:10" },
            { user: USERS.HANSEOL, text: "디자인 거의 다 완성됐어요!", type: "text", time: "17:12" }
        ];

        const container = document.getElementById('messages-container');
        const input = document.getElementById('msg-input');
        const sendBtn = document.getElementById('send-btn');
        const imageInput = document.getElementById('image-input');
        const chatWindow = document.getElementById('chat-window');

        // 메시지 렌더링 함수
        function renderMessages() {
            container.innerHTML = '';
            messages.forEach((msg, idx) => {
                const isMe = msg.user.name === ME.name;
                const showProfile = idx === 0 || messages[idx-1].user.name !== msg.user.name;

                const msgDiv = document.createElement('div');
                msgDiv.className = `flex ${isMe ? 'justify-end' : 'justify-start'} items-end gap-2`;

                let profileHTML = !isMe && showProfile 
                    ? `<div class="w-9 h-9 rounded-full ${msg.user.color} flex-shrink-0 flex items-center justify-center font-bold text-white text-xs border-2 border-white shadow-sm">${msg.user.name[0]}</div>`
                    : !isMe ? `<div class="w-9"></div>` : '';

                let contentHTML = `
                    <div class="flex flex-col ${isMe ? 'items-end' : 'items-start'} max-w-[75%]">
                        ${!isMe && showProfile ? `<span class="text-[10px] font-bold text-purple-400 mb-1 ml-1">${msg.user.name}</span>` : ''}
                        <div class="flex ${isMe ? 'flex-row-reverse' : 'flex-row'} items-end gap-1.5">
                            <div class="px-4 py-2.5 shadow-sm ${isMe ? 'bg-[#1E0A40] text-white bubble-me' : 'bg-white text-[#1E0A40] bubble-other'}">
                                ${msg.type === 'text' ? `<p class="text-[14px] leading-relaxed">${msg.text}</p>` : `<img src="${msg.content}" class="rounded-lg max-w-full">`}
                            </div>
                            <span class="text-[9px] text-purple-300 font-medium">${msg.time}</span>
                        </div>
                    </div>
                `;

                msgDiv.innerHTML = profileHTML + contentHTML;
                container.appendChild(msgDiv);
            });
            chatWindow.scrollTop = chatWindow.scrollHeight;
        }

        // 전송 기능
        function send(text, type = 'text', content = null) {
            if(!text.trim() && !content) return;
            const now = new Date();
            messages.push({
                user: ME,
                text: text,
                type: type,
                content: content,
                time: now.getHours() + ":" + now.getMinutes().toString().padStart(2, '0')
            });
            input.value = '';
            renderMessages();
        }

        // 이벤트 리스너
        sendBtn.addEventListener('click', () => send(input.value));
        input.addEventListener('keypress', (e) => e.key === 'Enter' && send(input.value));
        
        imageInput.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if(file) {
                const reader = new FileReader();
                reader.onload = (event) => send("", 'image', event.target.result);
                reader.readAsDataURL(file);
            }
        });

        // 초기 실행
        renderMessages();
        lucide.createIcons(); // 아이콘 로드
    </script>
</body>
</html>
